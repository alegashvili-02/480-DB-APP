<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" alignment="CENTER"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.ClientAutoBookController">

    <Label text="Auto Book Room"/>

    <TextField fx:id="hotelName" promptText="Hotel Name"/>

    <TextField fx:id="startDate" promptText="Start Date (YYYY-MM-DD)"/>
    <TextField fx:id="endDate" promptText="End Date (YYYY-MM-DD)"/>

    <Button text="Auto Book" onAction="#autoBook"/>

    <TextArea fx:id="resultArea" prefHeight="200" prefWidth="350"/>

    <Button text="Back" onAction="#back"/>
</VBox>