<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>


<VBox spacing="10" alignment="CENTER"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.ClientReviewController">

    <Label text="Submit Review"/>

    <TextField fx:id="hotelId" promptText="Hotel ID"/>
    <TextField fx:id="rating" promptText="Rating (1-5)"/>
    <TextField fx:id="message" promptText="Message"/>

    <Button text="Submit" onAction="#submit"/>

    <Label fx:id="status"/>

    <Button text="Back" onAction="#back"/>

</VBox>
