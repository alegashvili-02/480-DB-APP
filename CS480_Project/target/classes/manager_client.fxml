<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" alignment="CENTER"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.ManagerClientController">

    <Label text="Client Management"/>


    <Label text="DELETE CLIENT: Email only (WARNING: removes all related data)"/>

    <TextField fx:id="emailField" promptText="Client Email"/>

    <Button text="Delete Client" onAction="#delete"/>

    <Label fx:id="status"/>

    <Button text="Back" onAction="#back"/>
</VBox>
