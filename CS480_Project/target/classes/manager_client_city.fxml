<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" alignment="CENTER"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.ManagerCityQueryController">

    <Label text="Client City Query"
           style="-fx-font-size:18px;"/>

    <Label text="City C1 (client address)"/>
    <TextField fx:id="city1"/>

    <Label text="City C2 (hotel booking)"/>
    <TextField fx:id="city2"/>

    <Button text="Search" onAction="#search"/>

    <TextArea fx:id="resultArea" prefHeight="250"/>

    <Button text="Back" onAction="#back"/>

</VBox>